{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gemma-4-chat",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-30",
  "ai": {
    "binding": "AI"
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
